container_commands:
  install_requirements:
    command: "pip install -r /var/app/staging/djangotutorial/requirements.txt"

option_settings:
    aws:elasticbeanstalk:application:environment:
        DJANGO_SETTINGS_MODULE: "mysite.settings"
        PYTHONPATH: "/var/app/current/djangotutorial"
    aws:elasticbeanstalk:container:python:
        WSGIPath: mysite.wsgi

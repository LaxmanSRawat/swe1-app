container_commands:
  run_migrations:
    command: "python djangotutorial/manage.py migrate"
    leader_only: true

option_settings:
    aws:elasticbeanstalk:application:environment:
        DJANGO_SETTINGS_MODULE: "mysite.settings"
        PYTHONPATH: "/var/app/current/djangotutorial"
    aws:elasticbeanstalk:container:python:
        WSGIPath: mysite.wsgi
